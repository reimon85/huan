    {
      "parameters": {
        "jsCode": "// Parse LLM response and format with header/footer\nconst llmResponse = $input.first().json;\nconst today = new Date().toLocaleDateString('es-ES', { \n  weekday: 'long', \n  year: 'numeric', \n  month: 'long', \n  day: 'numeric' \n});\nconst now = new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });\n\nlet responseText = '';\n\nif (llmResponse.content && Array.isArray(llmResponse.content)) {\n  responseText = llmResponse.content[0].text;\n} else if (llmResponse.text) {\n  responseText = llmResponse.text;\n} else if (typeof llmResponse === 'string') {\n  responseText = llmResponse;\n} else {\n  responseText = JSON.stringify(llmResponse, null, 2);\n}\n\nconst disclaimer = `---\n*Generado: ${today} ${now} | Este briefing es informaci\u00f3n educativa, no consejo de inversi\u00f3n. Trading involves substantial risk of loss.*\n`;\n\nconst formattedBriefing = `# BRIEFING PRE-MERCADO \u2014 ${today}\\n\\n${responseText}\\n\\n${disclaimer}`;\n\n\nreturn {\n  json: {\n    briefing: formattedBriefing,\n    raw_response: responseText,\n    date: today,\n    generated_at: now\n  }\n};"
      },
      "id": "parse-response",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1220,
        400
      ]
    },
    {
      "parameters": {
        "filePath": "=/data/sessions/briefing_{{ $json.date }}.md",
        "data": "={{ $json.briefing }}",
