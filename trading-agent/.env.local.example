# ===========================================
# TRADING AGENT - CONFIGURACIÓN
# ===========================================
# Copia este archivo a .env.local y rellena los valores
# ===========================================

# ===========================================
# n8n Authentication
# ===========================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=TU_PASSWORD_AQUI

# ===========================================
# LLM Configuration
# ===========================================
ANTHROPIC_API_KEY=sk-ant-TU_API_KEY_AQUI
LLM_MODEL=claude-sonnet-4-20250514

# ===========================================
# Webhook
# ===========================================
WEBHOOK_URL=http://localhost:5678
WEBHOOK_SECRET=TU_WEBHOOK_SECRET

# ===========================================
# Telegram (Opcional - para notificaciones)
# ===========================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ===========================================
# n8n Protocol
# ===========================================
N8N_PROTOCOL=http
N8N_HOST=localhost

# ===========================================
# Future API Keys (descomenta según necesites)
# ===========================================
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# TRADING_ECONOMICS_API_KEY=
# EIA_API_KEY=
