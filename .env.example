# Trading Companion — Plantilla de configuración
# Copia este archivo a `.env` y rellena los valores necesarios
# NUNCA subas `.env` a git — ya está en .gitignore

# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
APP_NAME="Trading Companion"
APP_VERSION="0.2.0"
DEBUG=false

# ---------------------------------------------------------------------------
# Proveedor LLM (Hermes Agent)
# ---------------------------------------------------------------------------
# Hermes lee su propia config en ~/.hermes/config.yaml
# Pero también puedes exportar la API key en tu shell:
# export MINIMAX_API_KEY="sk-cp-TU_API_KEY_AQUI"
# export OPENROUTER_API_KEY="sk-or-TU_API_KEY_AQUI"
# export ANTHROPIC_API_KEY="sk-ant-TU_API_KEY_AQUI"

# ---------------------------------------------------------------------------
# Fuentes de datos directas (no requieren API key)
# ---------------------------------------------------------------------------
# Precios: Yahoo Finance
# Calendario: ForexFactory
# Sentiment: Alternative.me Fear & Greed + VIX
# Noticias: ForexLive RSS
# Crypto: CoinGecko

# Legacy: si aún usas n8n, descomenta y configura:
# WEBHOOK_URL=http://localhost:5678
# N8N_URL=http://localhost:5678

# ---------------------------------------------------------------------------
# Wiki (legacy FastAPI, opcional)
# ---------------------------------------------------------------------------
WIKI_CONTENT_PATH="./trading_companion/wiki/content"
WIKI_DB_PATH="./data/wiki.db"

# ---------------------------------------------------------------------------
# API Legacy (solo si necesitas el servidor FastAPI)
# ---------------------------------------------------------------------------
API_HOST="0.0.0.0"
API_PORT=8000
API_RELOAD=true

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"
